<!DOCTYPE html>
<html lang="{{ current_locale() }}">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>404 —
			{{ t('common.app_name') }}</title>
		 <script src="https://cdn.tailwindcss.com"></script>
	</head>
	<body class="bg-[#f9e4db] min-h-screen flex items-center justify-center">

		<div class="text-center px-4">
			<div class="text-8xl font-black text-brand-200 mb-4">404</div>
			<h1 class="text-2xl font-bold text-gray-800 mb-2">
				{% if current_locale() == 'cs' %}Stránka nenalezena{% else %}Page not found
				{% endif %}
			</h1>
			<p class="text-sm mb-8">
				{% if current_locale() == 'cs' %}
					Stránka kterou hledáte neexistuje nebo byla přesunuta.
				{% else %}
					The page you are looking for does not exist or has been moved.
				{% endif %}
			</p>
			<a href="{{ base_path }}/{{ locale == 'cs' ? 'cs/registrace' : 'en/registration' }}" class="inline-block bg-[#743a25] hover:bg-[#5e2e1c] text-white
					              text-sm font-semibold px-6 py-3 rounded-xl transition-colors">
				{% if current_locale() == 'cs' %}← Zpět na formulář{% else %}← Back to form
				{% endif %}
			</a>
		</div>

	</body>
</html>


