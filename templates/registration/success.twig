{% extends 'layouts/app.twig' %}

{% block title %}
	{{ t('registration.success_title') }}
{% endblock %}

{% block content %}
	<div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-10 text-center">
		<div class="text-5xl mb-4">🎉</div>
		<h1 class="text-2xl font-bold text-gray-900 mb-3">
			{{ t('registration.success_title') }}
		</h1>
		<p class="text-gray-500 text-sm mb-6">
			{{ t('registration.success_text') }}
		</p>
		<a href="{{ base_path }}/{{ current_locale() == 'cs' ? 'cs/registrace' : 'en/registration' }}" class="text-[#743a25] hover:underline text-sm">
			{% if current_locale() == 'cs' %}← Zpět na formulář
				{% else %}← Back to form
			{% endif %}
		</a>
	</div>
{% endblock %}
