<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ t('admin.login_title') }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f9e4db] min-h-screen flex items-center justify-center">

<div class="bg-white rounded-2xl shadow-sm border border-brand-200 p-8 w-full max-w-sm">

    <div class="text-center mb-8">
        <div class="text-4xl mb-3">🔐</div>
        <h1 class="text-xl font-bold text-brand-900">
            {{ t('admin.login_title') }}
        </h1>
    </div>

    {% if error %}
    <div class="mb-4 bg-red-50 border border-red-200 text-red-700
                text-sm rounded-lg px-4 py-3">
        {{ error }}
    </div>
    {% endif %}

    <form method="POST" action="{{ base_path }}/admin/login">
        <div class="mb-4">
            <label class="block text-sm font-semibold text-[#5e2e1c] mb-1">
                {{ t('admin.username') }}
            </label>
            <input
                type="text"
                name="username"
                autocomplete="username"
                required
                class="w-full rounded-lg border border-brand-300 px-3 py-2 text-sm
                       focus:outline-none focus:ring-2 focus:ring-[#d96e45]"
            >
        </div>

        <div class="mb-6">
            <label class="block text-sm font-semibold text-[#5e2e1c] mb-1">
                {{ t('admin.password') }}
            </label>
            <input
                type="password"
                name="password"
                autocomplete="current-password"
                required
                class="w-full rounded-lg border border-brand-300 px-3 py-2 text-sm
                       focus:outline-none focus:ring-2 focus:ring-[#d96e45]"
            >
        </div>

        <button
            type="submit"
            class="w-full bg-[#743a25] hover:bg-[#5e2e1c] text-white font-semibold
                   py-2.5 rounded-xl transition-colors text-sm"
        >
            {{ t('common.btn_login') }}
        </button>
    </form>
</div>

</body>
</html>


